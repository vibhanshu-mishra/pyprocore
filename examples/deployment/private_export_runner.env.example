# PyProcore private export runner environment template.
# Copy to a private location outside the repository. Do not commit real values.

PROCORE_AUTH_MODE=client_credentials
PROCORE_CLIENT_ID=replace-with-client-id
PROCORE_CLIENT_SECRET=replace-with-client-secret
PROCORE_REDIRECT_URI=http://localhost
PROCORE_LOGIN_URL=https://login.procore.com
PROCORE_API_BASE=https://api.procore.com
PROCORE_COMPANY_ID=12345

PROCORE_TOKEN_STORE_BACKEND=file
PROCORE_TOKEN_STORE_PATH=/opt/pyprocore/token-stores/production/token_store.json

PYPROCORE_EXPORT_ROOT=/opt/pyprocore/exports/production
PYPROCORE_LOG_DIR=/opt/pyprocore/logs/production
