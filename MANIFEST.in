include README.md
include CHANGELOG.md
include LICENSE
include pyproject.toml
include requirements.txt
include .env.example
include .coveragerc
include .flake8
include Dockerfile
include docker-compose.yml
include .dockerignore
recursive-include pyprocore py.typed
recursive-include docs *.md
recursive-include examples *.py *.json *.md *.yml *.yaml *.sh *.ps1 *.command *.plist
recursive-include scripts *.py
recursive-include tests *.py
exclude .env
exclude .env.*
exclude token_store.json
exclude pyprocore/auth/token_store.json
recursive-exclude * __pycache__
recursive-exclude * *.py[co]
recursive-exclude .git *
recursive-exclude .venv *
recursive-exclude downloads *
recursive-exclude logs *
recursive-exclude htmlcov *
recursive-exclude pyprocore-runs *
recursive-exclude webhook-events *
recursive-exclude project-context *
recursive-exclude ai-export *
recursive-exclude exports *
