# Copy this file to .env for local development.
# Do not commit real .env files, OAuth tokens, token stores, or secrets.
#
# Use production URLs with production credentials.
# Use sandbox URLs only with sandbox credentials.
# CI and scheduled automation need a deliberate token-store strategy.

PROCORE_CLIENT_ID=
PROCORE_CLIENT_SECRET=

# Auth modes:
# - authorization_code is the default user OAuth flow.
# - client_credentials is for Procore Data Connection Apps / server-to-server auth.
# Unknown values are rejected. Client Credentials uses app/service-account
# permissions and renews by requesting a new token, normally without refresh_token.
PROCORE_AUTH_MODE=authorization_code

# Required for authorization_code mode. Not required for client_credentials mode.
PROCORE_REDIRECT_URI=http://localhost

PROCORE_LOGIN_URL=https://login.procore.com
PROCORE_API_BASE=https://api.procore.com
PROCORE_COMPANY_ID=
